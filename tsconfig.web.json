{
  "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
  "include": [
    "app/renderer/env.d.ts",
    "app/renderer/**/*",
    "app/renderer/**/*.tsx",
    "app/shared/*.d.ts",
    "app/preload/*.d.ts",
    "utils/**/*.ts",
    "app",
    "./components",
    "src",
  ],
  "compilerOptions": {
    "composite": true,
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "paths": {
      "@components/*": [
        "./components/*"
      ],
      "@renderer/*": [
        "./app/renderer/*"
      ],
      "@main/*": [
        "./app/main/*"
      ],
      "@utils/*": [
        "./utils/*"
      ],
      "@shared/*": [
        "./app/shared/*"
      ]
    }
  }
}