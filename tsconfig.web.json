{
  "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
  "include": [
    "src/renderer/env.d.ts",
    "src/renderer/**/*",
    "src/renderer/**/*.tsx",
    "src/shared/*.d.ts",
    "src/preload/*.d.ts",
    "utils/**/*.ts",
   "src",
  
  ],
  "compilerOptions": {
    "composite": true,
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "paths": {
      "@renderer/*": [
        "./src/renderer/*"
      ],
      "@main/*":["./src/main/*"],
      "@utils/*":["./utils/*"],
      "@shared/*":["./src/shared/*"]
    }
  }
}
