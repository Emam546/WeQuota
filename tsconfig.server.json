{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": [
      "ES2020"
    ],
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "paths": {
      "@serv/*": [
        "./server/src/*"
      ],
      "@utils/*": [
        "./utils/*"
      ],
      "@main/*": [
        "./app/main/*"
      ],
    }
  },
  "include": [
    "server",
    "app/main",
    "utils"
  ],
  "exclude": [
    "node_modules",
    "dist",
  ]
}