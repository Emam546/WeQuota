{
  "extends": "@electron-toolkit/tsconfig/tsconfig.node.json",
  "include": [
    "electron.vite.config.*",
    "app/main/**/*",
    "app/preload/**/*",
    "app/renderer/**/*",
    "./utils",
    "shared/**/*.d.ts",
    "src"
  ],
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": false,
    "types": [
      "electron-vite/node"
    ],
    "paths": {
      "@src/*": [
        "./src/*"
      ],
      "@renderer/*": [
        "./app/renderer/*"
      ],
      "@utils/*": [
        "./utils/*"
      ],
      "@shared/*": [
        "./shared/*"
      ],
      "@main/*": [
        "./app/main/*"
      ],
    }
  }
}