{
  "compilerOptions": {
    "target": "es5",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "module": "commonjs",
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "paths": {
      "@src/*": [
        "./src/*"
      ],
      "@shared/*": [
        "./shared/*"
      ],
      "@utils/*": [
        "./utils/*"
      ],
      "@renderer/*": [
        "./app/renderer/*"
      ],
      "@main/*": [
        "./app/main/*"
      ],
      "@components/*": [
        "./components/*"
      ],
    },
    "plugins": [
      {
        "name": "next"
      }
    ],
    "skipLibCheck": true
  },
  "include": [
    "src",
    "shared",
    "utils",
    "./components",
    "src/tailwind.config.js", "next.config.ts",
  ],
  "exclude": [
    "node_modules",
    "app",
    "server",
    "dist",
    "out"
  ]
}