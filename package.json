{
  "name": "WeQuota",
  "version": "1.0.0",
  "description": "show like the user usage",
  "main": "./out/main/index.js",
  "scripts": {
    "build:server": "ts-node build.ts",
    "build:next": "next build src",
    "build": "npm run build:server && npm run build:next",
    "build:desk": "npm run build:next && electron-vite build",
    "test": "jest",
    "start": "node -r module-alias/register ./dist/server/src --env=production",
    "dev": "nodemon",
    "lint": "eslint server app server src --ext .ts,.tsx",
    "lint:src": "tsc --noEmit && eslint  src",
    "lint:server": "eslint -c  --ext  .ts server/src/ ",
    "lint:electron": "eslint --ext .ts app",
    "start:desk": "electron-vite preview",
    "dev:desk": "electron-vite dev",
    "build:win": "electron-builder --win -p never&&innosetup-compiler setup.iss --verbose",
    "pack": "npm run build:desk&&npm run build:win"
  },
  "_moduleAliases": {
    "@serv": "dist/server/src",
    "@main": "dist/app/main",
    "@utils": "dist/utils"
  },
  "nodemonConfig": {
    "watch": [
      "./server/src"
    ],
    "ext": "ts, html",
    "exec": "ts-node --project tsconfig.server.json --files -r tsconfig-paths/register ./server/src"
  },
  "keywords": [
    "we",
    "automation",
    "nodejs",
    "electron",
    "nextjs"
  ],
  "author": "ImamAshour",
  "license": "ISC",
  "devDependencies": {
    "@types/command-line-args": "^5.2.3",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/d3": "^7.4.3",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@vitejs/plugin-react": "^5.1.1",
    "@tailwindcss/postcss": "^4.3.1",
    "@tailwindcss/vite": "^4.2.2",
    "autoprefixer": "^10.4.21",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "innosetup-compiler": "^6.3.1",
    "jest": "^30.3.0",
    "next": "^16.2.9",
    "nodemon": "^3.1.14",
    "postcss": "^8.5.15",
    "prettier": "^3.7.4",
    "sass-embedded": "^1.100.0",
    "tailwindcss": "^4.3.1",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^6.2.0"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@electron-toolkit/utils": "^4.0.0",
    "@reduxjs/toolkit": "^2.12.0",
    "@tanstack/react-query": "^5.99.0",
    "axios": "^1.15.0",
    "classnames": "^2.5.1",
    "command-line-args": "^6.0.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "d3": "^7.9.0",
    "dotenv": "^17.2.3",
    "electron-auto-launch": "^5.0.7",
    "electron-serve": "^0.4.1",
    "electron-updater": "^6.3.9",
    "express": "^4.21.2",
    "express-async-errors": "^3.1.1",
    "helmet": "^8.2.0",
    "jet-logger": "^2.2.3",
    "lucide-react": "^0.546.0",
    "module-alias": "^2.3.4",
    "morgan": "^1.11.0",
    "motion": "^12.23.24",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-hook-form": "^7.72.1",
    "react-redux": "^9.3.0"
  }
}
